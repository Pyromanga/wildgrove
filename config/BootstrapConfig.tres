[gd_resource type="Resource" script_class="BootstrapConfig" load_steps=18 format=3]

[ext_resource type="Script" path="res://scripts/core/BootstrapConfig.gd" id="1_config"]
[ext_resource type="Script" path="res://scripts/core/ServiceDefinition.gd" id="2_def"]

[sub_resource type="Resource" id="Resource_savesystem"]
