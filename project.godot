; Engine configuration file.
; WildGrove — RuneScape × Animal Crossing × Stardew Valley × Zelda
; Godot 4.3 — Mobile 3D

[configuration]

config_version=5

[application]

config/name="WildGrove"
config/description="Ein Abenteuer-RPG mit Farming, Dorfbau und Dungeons"
config/version="0.1.0"
config/tags=PackedStringArray("mobile", "rpg", "3d")
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Mobile")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[physics]

3d/default_gravity=9.8

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=0
lights_and_shadows/directional_shadow/size=2048
# ─────────────────────────────────────────────────────────────────────────────
# project.godot — [autoload] Sektion
# ─────────────────────────────────────────────────────────────────────────────
#
# REIHENFOLGE IST KRITISCH:
#   1. Logger        — kein Autoload-Dep, muss zuerst da sein
#   2. SimpleTerminal — connectet sich auf Logger.on_log in _init()
#                       muss VOR Kernel sein damit Kernel-Logs sichtbar sind
#   3. Kernel        — nutzt Logger (immer verfügbar), ist unabhängig von SimpleTerminal
#
# SimpleTerminal ist KEIN Service des Kernels — es ist ein Debugging-Tool
# das unabhängig vom Service-Lifecycle läuft.
# ─────────────────────────────────────────────────────────────────────────────

[autoload]
Logger="*res://scripts/logger/Logger.gd"
EventBus="*res://scripts/events/EventBus.gd
SimpleTerminal="*res://scripts/debug/SimpleTerminal.gd"
[autoload_backup]
Kernel="*res://scripts/core/Kernel.gd"